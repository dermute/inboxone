# Copy this file to .env and fill in real values. Never commit .env.

# Password required to log into the web UI (treat like a house key, not a bank password).
APP_PASSWORD=change-me

# Random secret used to sign the session cookie. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me

# Symmetric key used to encrypt stored IMAP/SMTP passwords and OAuth tokens at rest.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Do NOT rotate this after accounts have been added without a migration - existing
# encrypted values would become unreadable.
ENCRYPTION_KEY=change-me

# SQLite database location inside the container (leave as-is when using docker-compose,
# it maps to the ./data bind mount on the host).
DATABASE_URL=sqlite+aiosqlite:////data/app.db

# Default polling interval (seconds) for accounts that don't override it. Minimum 30.
SYNC_DEFAULT_INTERVAL_SECONDS=60
